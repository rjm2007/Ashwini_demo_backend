# Database
# Important — read this carefully, this is a real footgun: DATABASE_URL in this same file is a literal string.
# env_file values are passed to containers as-is, with no variable substitution inside them.
# That means writing ${POSTGRES_PASSWORD} inside DATABASE_URL will NOT work.
# You must write the same real password out twice, literally:
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://warranty_user:<the-same-strong-value>@postgres:5432/warranty

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=warranty-platform-poc
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/warranty-processing-queue

# Qdrant (use http://qdrant:6333 for the bundled local container, or a Qdrant Cloud URL)
QDRANT_URL=http://qdrant:6333
# For scripts run on the host (test-rag/*.py), optional override; default maps qdrant → localhost
QDRANT_URL_LOCAL=http://localhost:6333

# Docling PDF service. Use localhost from host; docling:5001 inside Docker network.
DOCLING_URL=http://localhost:5001
DOCLING_SERVE_URL=http://docling:5001
PARSER_PRIMARY=docling_structured
ENABLE_SECTION_CLASSIFICATION=true
ENABLE_SCHEMA_PIPELINE=true
ENABLE_VEHICLE_LLM_FALLBACK=true
GATE_HEAVY_ON_CERTIFY=true

# OCR chain (same as test-rag): auto | textract | docling | openai_vision
OCR_METHOD=auto

# AI service — contextual blurb before embed (set false to speed up ingest)
ENABLE_CONTEXTUAL_RETRIEVAL=true
# Phase 2: OpenAI small-model rerank on top hybrid candidates
ENABLE_RERANKER=true
RERANKER_CANDIDATES=20
RERANKER_PROVIDER=openai

# RAG upgrades (disable to restore prior behavior)
ENABLE_PARENT_CHILD=true
ENABLE_STRUCTURED_REASONING=true
ENABLE_RETRIEVAL_QUALITY=true
ENABLE_QUERY_DECOMPOSITION=true
RETRIEVAL_SCORE_THRESHOLD=0.01
RETRIEVAL_MIN_CHUNKS=3
RETRIEVAL_RETRY_TOP_K=50
QDRANT_API_KEY=
QDRANT_COLLECTION=warranty_chunks
QDRANT_COLLECTION_V2=warranty_chunks_v2

# LLMs
OPENAI_API_KEY=
SMALL_MODEL=gpt-5.4-mini
LARGE_MODEL=gpt-5.5
ANTHROPIC_API_KEY=

# Service Ports
BACKEND_PORT=3001
AI_SERVICE_PORT=8000
FRONTEND_PORT=3000

# Auth
JWT_SECRET=
JWT_EXPIRY=24h

# Service URLs
AI_SERVICE_URL=http://ai-service:8000
BACKEND_URL=http://backend:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
